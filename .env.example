# DART 공시 API (필수) — https://opendart.fss.or.kr 에서 발급
DART_API_KEY=...

# Naver 검색 API (선택 — 없으면 DuckDuckGo 폴백)
# https://developers.naver.com 에서 발급 (무료, 하루 25,000건)
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# 로컬 LLM (Ollama)
# Ollama 설치: https://ollama.com
# 모델 다운로드: ollama pull llama3.2
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_BASE_URL=http://localhost:11434

# 임베딩 모델 (로컬 — HuggingFace sentence-transformers)
EMBED_MODEL=snunlp/KR-SBERT-V40K-klueNLI-augSTS
